{
  "manifest_version": 3,
  "name": "Timeguessr Social Extension",
  "version": "2.2.4",
  "icons": {
    "32": "icon/32.png"
  },
  "action": {
    "default_popup": "src/popup.html"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background.ts"
  },
  "content_scripts": [
    {
      "js": ["src/content/content-script.ts"],
      "css": ["src/style/leaderboard.css"],
      "matches": [
        "https://timeguessr.com/play*",
        "https://timeguessr.com/final-score*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected/enhanced-map.injected.js",
        "src/injected/enhanced-final-map.injected.js",
        "src/injected/leaderboard.injected.js"
      ],
      "matches": ["https://timeguessr.com/*"]
    }
  ]
}
