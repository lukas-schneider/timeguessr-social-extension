{
  "name": "timeguessr-social-extension",
  "private": true,
  "version": "2.2.5",
  "type": "module",
  "scripts": {
    "postinstall": "wxt prepare",
    "compile": "tsc --noEmit",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "api:get": "aws --region eu-central-1 apigateway get-export --rest-api-id ck1hb2hxya --stage-name prod --export-type oas30 --accepts \"application/yaml\" openapi-spec.yaml",
    "api:gen": "openapi-generator-cli generate",
    "lint": "prettier --write ."
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.20.0",
    "@types/apple-mapkit-js-browser": "^5.78.1",
    "@types/webextension-polyfill": "~0.12.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "webextension-polyfill": "~0.12.0",
    "wxt": "^0.20.27"
  }
}
